### REQUIRED

# Master secret (generate with: openssl rand -base64 32)
SECRET_KEY_BASE="change-this-to-a-random-string"

# Public URL where Chathouse is accessible
CLIENT_URL="https://chat.yourdomain.com"

### OPTIONAL

# Database (defaults work out of the box with the bundled MariaDB)
MARIADB_ROOT_PASSWORD=rootpassword
MARIADB_DATABASE=chathouse
MARIADB_USER=chathouse
MARIADB_PASSWORD=chathouse

# Email (if not configured, emails are sent via direct MX lookup)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Chathouse <noreply@example.com>"
SMTP_MOCK=false

# Port the app is exposed on (default: 80)
# PORT=80
